# BOSS 直聘账号（可选，支持扫码登录）
BOSS_USERNAME=
BOSS_PASSWORD=

# 模型配置（仅用于 compatibility，API Key 需在 GUI 中配置）
MODEL_NAME=claude-sonnet-4-6

# ============ 本地 LLM 配置 ============
# LLM 类型：openai（OpenAI 兼容接口）/ ollama
LOCAL_LLM_TYPE=openai

# API 基础地址（根据你的部署方式修改）
# - Qwen 阿里云：https://dashscope.aliyuncs.com/compatible-mode/v1
# - Ollama 本地：http://localhost:11434/v1
# - vLLM 本地部署：http://localhost:8000/v1
LOCAL_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称
LOCAL_LLM_MODEL=qwen3.5-plus

# 注意：API Key 不再在此处配置！
# 请通过 GUI 界面「岗位配置」->「API 配置」中设置并保存
# API Key 会加密存储到系统钥匙串，更安全

# 存储路径
RESUME_SAVE_DIR=./resumes
OUTPUT_DIR=./output
