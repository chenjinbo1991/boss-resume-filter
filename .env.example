# BOSS 直聘账号（可选，支持扫码登录）
BOSS_USERNAME=
BOSS_PASSWORD=

# Claude API（用于简历匹配评分，如使用本地 LLM 则不需要）
ANTHROPIC_API_KEY=

# 模型配置
MODEL_NAME=claude-sonnet-4-6

# ============ 本地 LLM 配置（如使用 Qwen 等本地模型）============
# LLM 类型：openai（OpenAI 兼容接口）/ ollama
LOCAL_LLM_TYPE=openai

# API 基础地址（根据你的部署方式修改）
# Qwen 通过 OpenAI 兼容接口：http://localhost:8000/v1
# Ollama: http://localhost:11434/v1
LOCAL_LLM_BASE_URL=http://localhost:8000/v1

# 模型名称（根据你的实际模型配置）
LOCAL_LLM_MODEL=qwen-plus

# API Key（Ollama 可留空，其他服务填写对应密钥）
LOCAL_LLM_API_KEY=your-api-key-here

# 存储路径
RESUME_SAVE_DIR=./resumes
OUTPUT_DIR=./output
