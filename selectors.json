{
  "_comment": "BOSS直聘页面选择器配置 — DOM 结构变化时修改此文件，无需改代码",
  "_version": "1.0",

  "candidate_card": {
    "_desc": "候选人卡片定位",
    "all_cards_xpath": "xpath://*[@data-geekid]",
    "card_by_id_css": "css:[data-geekid=\"{geek_id}\"]",
    "geek_id_attr": "data-geekid"
  },

  "name_extraction": {
    "_desc": "从卡片中提取候选人姓名",
    "name_xpath": "xpath:.//*[contains(@class, \"name\") and not(contains(@class, \"wrap\"))]",
    "col2_xpath": "xpath:.//*[contains(@class, \"col-2\")]"
  },

  "greet_button": {
    "_desc": "打招呼/沟通按钮",
    "button_xpath": "xpath:.//*[text()=\"继续沟通\" or text()=\"立即沟通\" or text()=\"打招呼\" or contains(text(), \"继续沟通\") or contains(text(), \"立即沟通\") or contains(text(), \"打招呼\")]"
  },

  "iframe": {
    "_desc": "推荐列表 iframe 定位",
    "selector": "tag:iframe",
    "src_match": "recommend"
  },

  "scroll": {
    "_desc": "滚动控制和到底检测",
    "bottom_texts": ["到底", "没有更多"],
    "_container_js_selectors_deprecated": "不再使用静态选择器，改为从 [data-geekid] 卡片向上遍历 DOM 找 overflow:auto/scroll 的祖先元素",
    "scroll_amount": 800
  },

  "captcha_detection": {
    "_desc": "安全验证/验证码检测",
    "css_selectors": [
      ".geetest_panel",
      ".captcha-box",
      ".slider-captcha",
      ".verify-captcha",
      ".captcha-container",
      "#captcha",
      ".yoda-modal",
      ".geetest_widget",
      ".geetest_radar_tip"
    ],
    "keywords": [
      "请完成安全验证",
      "滑块验证",
      "请拖动滑块",
      "拖拽拼图",
      "检测到异常操作",
      "请先完成验证",
      "行为验证",
      "请完成验证",
      "拖动下方滑块",
      "请按住滑块"
    ]
  },

  "limit_detection": {
    "_desc": "沟通次数限制弹窗检测",
    "keywords": [
      "次数已用完",
      "沟通次数",
      "今日上限",
      "升级套餐",
      "立即升级",
      "联系次数",
      "已达上限",
      "今日剩余",
      "开通套餐",
      "购买套餐",
      "次数不足",
      "免费次数",
      "升级VIP",
      "VIP无限沟通",
      "体验VIP",
      "今日免费"
    ]
  },

  "greeting_verify": {
    "_desc": "打招呼成功验证标记文本",
    "success_marks": ["已沟通", "沟通过", "已发送"],
    "continue_mark": "继续沟通"
  }
}
